{
  "name": "ai-solutions-backend",
  "version": "1.0.0",
  "description": "Backend for AI-Solutions MERN stack",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes",
      "models",
      "middleware"
    ],
    "ignore": [
      "node_modules/**",
      "frontend/**",
      ".git/**",
      ".DS_Store",
      ".vite/**",
      ".env",
      "*.log",
      "*.tmp",
      "**/*~",
      "**/*.swp"
    ],
    "ext": "js,json",
    "delay": "2000",
    "legacyWatch": true
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
